{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install dependencies",
      "type": "shell",
      "command": "npm install",
      "inAgents": true,
      "runOptions": {
        "runOn": "worktreeCreated"
      }
    },
    {
      "label": "Dev server",
      "type": "shell",
      "command": "npm run dev",
      "inAgents": true
    },
    {
      "label": "Build",
      "type": "shell",
      "command": "npm run build",
      "inAgents": true
    },
    {
      "label": "Lint",
      "type": "shell",
      "command": "npm run lint",
      "inAgents": true
    },
    {
      "label": "Start",
      "type": "shell",
      "command": "npm run start",
      "inAgents": true
    },
    {
      "label": "Format",
      "type": "shell",
      "command": "npm run format",
      "inAgents": true
    }
  ]
}
